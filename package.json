{
  "name": "janus-ai-mobile",
  "version": "3.0.0",
  "private": true,
  "description": "JANUS AI · App móvil FinTech (Capacitor wrapper de la PWA)",
  "scripts": {
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "build:apk": "cap sync android && cd android && gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
